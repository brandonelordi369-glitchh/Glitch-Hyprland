#!/usr/bin/env zsh

# awg - Simple wallpaper changer using awww
# Usage: awg <image_path>

if [ -z "$1" ]; then
    echo "Usage: awg <image_path>"
    echo "Example: awg ~/Pictures/wallpaper.jpg"
    exit 1
fi

IMAGE_PATH="$1"

# Check if file exists
if [ ! -f "$IMAGE_PATH" ]; then
    echo "Error: File '$IMAGE_PATH' not found"
    exit 1
fi

# Change wallpaper with awww
awww img "$IMAGE_PATH" --transition-fps 75 --transition-type random

if [ $? -eq 0 ]; then
    echo "Wallpaper changed to: $IMAGE_PATH"
else
    echo "Error: Failed to change wallpaper"
    exit 1
fi
