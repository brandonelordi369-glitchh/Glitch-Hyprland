#!/usr/bin/env zsh
# awg - Wallpaper changer (awww) + automatic hyprlock sync
# Usage: awg <image_path>
if [ -z "$1" ]; then
    cat <<EOF
Usage: awg <image_path>
Example: awg ~/Pictures/wallpaper.jpg
         awg "/path/with spaces.jpg"
EOF
    exit 1
fi

IMAGE_PATH="${1:A}"

if [ ! -f "$IMAGE_PATH" ]; then
    echo "Error: File not found -> $IMAGE_PATH"
    exit 1
fi

awww img "$IMAGE_PATH" --transition-fps 75 --transition-type random

if [ $? -ne 0 ]; then
    echo "Error: Failed to change wallpaper"
    exit 1
fi

HYPRLOCK_CONF="$HOME/.config/hypr/hyprlock.conf"
if [ -f "$HYPRLOCK_CONF" ] && grep -q "background {" "$HYPRLOCK_CONF" 2>/dev/null; then
    sed -i "/background {/,/}/ s|path = .*|path = ${IMAGE_PATH}|" "$HYPRLOCK_CONF"
    echo "AWG: $IMAGE_PATH (wallpaper + hyprlock background)"
else
    echo "AWG: $IMAGE_PATH (wallpaper only; hyprlock.conf missing or has no background block)"
fi
