{
  // Workspaces
  "hyprland/workspaces": {
    "on-scroll-up": "hyprctl dispatch 'hl.dsp.focus({ workspace = \"r-1\" })'",
    "on-scroll-down": "hyprctl dispatch 'hl.dsp.focus({ workspace = \"r+1\" })'",
    // "on-click": "activate",
    "active-only": false,
    "all-outputs": true,
    "format": "{}",
    "format-icons": {
      "urgent": "",
      "active": "",
      "default": ""
    },
    "persistent-workspaces": {
      "*": 9
    }
  },

  // Window
  "hyprland/window": {
    "format": "{title}",
    "max-length": 50,          // έΗΡ tweak this (30έΑΥ60 is usually perfect)
    "tooltip": false,
    "rewrite": {
      "(.{50})": "$1..."       // optional: forces ellipsis in the config too
    }
  },


  // Empty
  "custom/empty": {
    "format": ""
  },


  // Rofi Application Launcher
  "custom/appmenu": {
    "format": "≤░μΗ",
    "on-click": "sleep 0.2;pkill rofi || rofi -show drun",
    "tooltip": false
  },


  // Power Menu
  "custom/exit": {
    "format": "ΎΑΣ",
    "on-click": "wlogout -b 5",
    "on-click-right": "hyprlock",
    "tooltip-format": "Left: Power menu\nRight: Lock screen"
  },

  // SwayNC
  "custom/notification": {
    "tooltip-format": "Left: Notifications\nRight: Do not disturb",
    "format": "{icon}",
    "format-icons": {
      "notification": "Όχγ",
      "none": "ΎΣ╢",
      "dnd-notification": "Ό░Ι<span foreground='red'><sup>ΎΣΕ</sup></span>",
      "dnd-none": "Ό░Ι",
      "inhibited-notification": "Όχγ",
      "inhibited-none": "ΎΣ╢",
      "dnd-inhibited-notification": "Ό░Ι<span foreground='red'><sup>ΎΣΕ</sup></span>",
      "dnd-inhibited-none": "Ό░Ι"
    },
    "return-type": "json",
    "exec-if": "which swaync-client",
    "exec": "swaync-client -swb",
    "on-click": "swaync-client -t -sw",
    "on-click-right": "swaync-client -d -sw",
    "escape": true
  },


  // System tray
  "tray": {
    "icon-size": 22,
    "spacing": 7
  },

  // Clock
  "clock": {
    "tooltip-format": "<tt><small>{calendar}</small></tt>",
    "timezone": "",
    "calendar": {
      "mode": "month",
      "mode-mon-col": 3,
      "weeks-pos": "right",
      "on-scroll": 1,
      "on-click-right": "mode",
      "format": {
	"months": "<span color='#bb9af7'><b>{}</b></span>",  // Purple
	"days": "<span color='#7aa2f7'><b>{}</b></span>",    // Blue
	"weeks": "<span color='#9ece6a'><b>W{}</b></span>",  // Green
	"weekdays": "<span color='#e0af68'><b>{}</b></span>",// Yellow
	"today": "<span background='#2ac3de' color='#1a1b26'><b><u>{}</u></b></span>" // Cyan background with dark text
      }
    },
    "actions": {
      "on-click-right": "mode",
      "on-click-forward": "tz_up",
      "on-click-backward": "tz_down",
      "on-scroll-up": "shift_up",
      "on-scroll-down": "shift_down"
    },
    "format": "≤░Δφ  {:%b %d   ≤░ξΦ  %H:%M}", //24 hour format
    "format-alt": "≤░Δφ  {:%Y-%m-%d   ≤░ξΦ  %H:%M:%S}",
    "interval": 1
  },


  // CPU
  "cpu": {
    "interval": 2,
    "format": "ΎΤ╝  {usage}%",
    "on-click": "kitty -e btop"
  },

  // Memory
  "memory": {
    "interval": 2,
    "format": "Ό┐Ζ  {}%",
    "on-click": "kitty -e btop"
  },

  // Harddisc space used
  "disk": {
    "interval": 10,
    "format": "ΎΓι  {percentage_used}% ",
    "path": "/",
    "on-click": "kitty -e btop"
  },


  // Power Profiles Daemon
  "power-profiles-daemon": {
    "format": "{icon}",
    "tooltip-format": "Power profile: {profile}\nDriver: {driver}",
    "tooltip": true,
    "format-icons": {
      "default": "ΎΗΖ",
      "performance": "ΎΔπ",
      "balanced": "ΎΗΖ",
      "power-saver": "ΎΒυ"
    }
  },

  // Pulseaudio
  "pulseaudio": {
    // "scroll-step": 1, // %, can be a float
    "format": "{icon} {volume}%",
    "format-bluetooth": "{volume}% {icon}ΎΛΦ {format_source}",
    "format-bluetooth-muted": "Ύγσ {icon}ΎΛΦ {format_source}",
    "format-muted": "Ύγσ {format_source}",
    "format-source": "{volume}% ΎΕ░",
    "format-source-muted": "ΎΕ▒",
    "format-icons": {
      "headphone": "ΎΑξ ",
      "hands-free": "ΎΨΡ ",
      "headset": "ΎΨΡ ",
      "phone": "ΎΓΧ ",
      "portable": "ΎΓΧ ",
      "car": "ΎΗ╣ ",
      "default": ["ΎΑο", "ΎΑρ", "ΎΑρ"]
    },
    "on-click": "pavucontrol"
  },

  // Bluetooth
  "bluetooth": {
    "format": "ΎΛΥ {status}",
    "format-disabled": "",
    "format-off": "",
    "interval": 30,
    "on-click": "blueman-manager",
    "format-no-controller": ""
  },

  // Other
  "user": {
    "format": "{user}",
    "interval": 60,
    "icon": false
  },

  // backlight:
  "backlight": {
    "format": "{icon} {percent}%",
    "format-icons": [
      "ΌΟΞ",
      "ΌΠΦ",
      "ΌΠΥ",
      "ΌΠΤ",
      "ΌΠΣ",
      "ΌΠΡ",
      "ΌΠΠ",
      "ΌΠΟ",
      "ΌΠΞ",
      "ΌΠΝ",
      "ΌΠΜ",
      "ΌΠΛ",
      "ΌΠΚ",
      "ΌΠΙ",
      "ΌΟδ"
    ],
    "scroll-step": 1
  }
}
