{
  // Workspaces
  "hyprland/workspaces": {
    "on-scroll-up": "hyprctl dispatch workspace r-1",
    "on-scroll-down": "hyprctl dispatch workspace r+1",
    // "on-click": "activate",
    "active-only": false,
    "all-outputs": true,
    "format": "{}",
    "format-icons": {
      "urgent": "",
      "active": "",
      "default": ""
    },
    "persistent-workspaces": {
      "*": 9
    }
  },

  // Window
  "hyprland/window": {
    "format": "{title}",
    "max-length": 50,          // ŌåÉ tweak this (30ŌĆō60 is usually perfect)
    "tooltip": false,
    "rewrite": {
      "(.{50})": "$1..."       // optional: forces ellipsis in the config too
    }
  },


  // Empty
  "custom/empty": {
    "format": ""
  },


  // Rofi Application Launcher
  "custom/appmenu": {
    "format": "¾░Żå",
    "on-click": "sleep 0.2;pkill rofi || rofi -show drun",
    "tooltip": false
  },


  // Power Menu
  "custom/exit": {
    "format": "’Ćæ",
    "on-click": "wlogout -b 5",
    "on-click-right": "hyprlock",
    "tooltip-format": "Left: Power menu\nRight: Lock screen"
  },

  // SwayNC
  "custom/notification": {
    "tooltip-format": "Left: Notifications\nRight: Do not disturb",
    "format": "{icon}",
    "format-icons": {
      "notification": "Ņ«Ü",
      "none": "’æČ",
      "dnd-notification": "Ņ░ł<span foreground='red'><sup>’æä</sup></span>",
      "dnd-none": "Ņ░ł",
      "inhibited-notification": "Ņ«Ü",
      "inhibited-none": "’æČ",
      "dnd-inhibited-notification": "Ņ░ł<span foreground='red'><sup>’æä</sup></span>",
      "dnd-inhibited-none": "Ņ░ł"
    },
    "return-type": "json",
    "exec-if": "which swaync-client",
    "exec": "swaync-client -swb",
    "on-click": "swaync-client -t -sw",
    "on-click-right": "swaync-client -d -sw",
    "escape": true
  },


  // System tray
  "tray": {
    "icon-size": 22,
    "spacing": 7
  },

  // Clock
  "clock": {
    "tooltip-format": "<tt><small>{calendar}</small></tt>",
    "timezone": "",
    "calendar": {
      "mode": "month",
      "mode-mon-col": 3,
      "weeks-pos": "right",
      "on-scroll": 1,
      "on-click-right": "mode",
      "format": {
	"months": "<span color='#bb9af7'><b>{}</b></span>",  // Purple
	"days": "<span color='#7aa2f7'><b>{}</b></span>",    // Blue
	"weeks": "<span color='#9ece6a'><b>W{}</b></span>",  // Green
	"weekdays": "<span color='#e0af68'><b>{}</b></span>",// Yellow
	"today": "<span background='#2ac3de' color='#1a1b26'><b><u>{}</u></b></span>" // Cyan background with dark text
      }
    },
    "actions": {
      "on-click-right": "mode",
      "on-click-forward": "tz_up",
      "on-click-backward": "tz_down",
      "on-scroll-up": "shift_up",
      "on-scroll-down": "shift_down"
    },
    "format": "¾░āŁ  {:%b %d   ¾░źö  %H:%M}", //24 hour format
    "format-alt": "¾░āŁ  {:%Y-%m-%d   ¾░źö  %H:%M:%S}",
    "interval": 1
  },


  // CPU
  "cpu": {
    "interval": 2,
    "format": "’Æ╝  {usage}%",
    "on-click": "kitty -e btop"
  },

  // Memory
  "memory": {
    "interval": 2,
    "format": "Ņ┐ģ  {}%",
    "on-click": "kitty -e btop"
  },

  // Harddisc space used
  "disk": {
    "interval": 10,
    "format": "’éĀ  {percentage_used}% ",
    "path": "/",
    "on-click": "kitty -e btop"
  },


  // Power Profiles Daemon
  "power-profiles-daemon": {
    "format": "{icon}",
    "tooltip-format": "Power profile: {profile}\nDriver: {driver}",
    "tooltip": true,
    "format-icons": {
      "default": "’åģ",
      "performance": "’ā¦",
      "balanced": "’åģ",
      "power-saver": "’ü¼"
    }
  },

  // Pulseaudio
  "pulseaudio": {
    // "scroll-step": 1, // %, can be a float
    "format": "{icon} {volume}%",
    "format-bluetooth": "{volume}% {icon}’Ŗö {format_source}",
    "format-bluetooth-muted": "’Ü® {icon}’Ŗö {format_source}",
    "format-muted": "’Ü® {format_source}",
    "format-source": "{volume}% ’ä░",
    "format-source-muted": "’ä▒",
    "format-icons": {
      "headphone": "’Ćź ",
      "hands-free": "’¢É ",
      "headset": "’¢É ",
      "phone": "’éĢ ",
      "portable": "’éĢ ",
      "car": "’å╣ ",
      "default": ["’Ć”", "’Ć©", "’Ć©"]
    },
    "on-click": "pavucontrol"
  },

  // Bluetooth
  "bluetooth": {
    "format": "’Ŗō {status}",
    "format-disabled": "",
    "format-off": "",
    "interval": 30,
    "on-click": "blueman-manager",
    "format-no-controller": ""
  },

  // Other
  "user": {
    "format": "{user}",
    "interval": 60,
    "icon": false
  },

  // backlight:
  "backlight": {
    "format": "{icon} {percent}%",
    "format-icons": [
      "ŅÄŹ",
      "ŅÅö",
      "ŅÅō",
      "ŅÅÆ",
      "ŅÅæ",
      "ŅÅÉ",
      "ŅÅÅ",
      "ŅÅÄ",
      "ŅÅŹ",
      "ŅÅī",
      "ŅÅŗ",
      "ŅÅŖ",
      "ŅÅē",
      "ŅÅł",
      "ŅÄø"
    ],
    "scroll-step": 1
  }
}
